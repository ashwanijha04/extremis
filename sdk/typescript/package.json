{
  "name": "@extremis/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for extremis — layered memory platform for AI agents, with built-in hallucination detection",
  "license": "MIT",
  "author": "Ashwani Jha <ashwanijha04@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashwanijha04/extremis"
  },
  "keywords": [
    "memory",
    "ai",
    "agents",
    "rag",
    "hallucination-detection",
    "claude",
    "openai",
    "llm",
    "agent-memory"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && node --test build-tests/tests/*.test.js",
    "clean": "rm -rf dist build-tests",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
