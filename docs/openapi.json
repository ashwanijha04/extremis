                    },
                    "log_checkpoint": {
                        "type": "string",
                        "title": "Log Checkpoint"
                    }
                },
                "type": "object",
                "required": [
                    "memories_created",
                    "memories_superseded",
                    "duration_seconds",
                    "log_checkpoint"
